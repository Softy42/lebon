#############################################
# Maison Mélina — .htaccess (Prod + Préprod)
#############################################


SetEnv BLOG_APP_ENV staging
SetEnv BLOG_DB_HOST db5010329327.hosting-data.io
SetEnv BLOG_DB_PORT 3306
SetEnv BLOG_DB_NAME dbs8753726
SetEnv BLOG_DB_USER dbu1316787
SetEnv BLOG_DB_PASS "@MaisonMelinaThierryAurelien@42"
SetEnv BLOG_DB_CHARSET utf8mb4
SetEnv BLOG_ADMIN_USER mm_backoffice_2026
SetEnv BLOG_ADMIN_PASSWORD_HASH "$2y$12$W652XRvNHxH12Dgz5E5tBe5FZa7F/W/Tcr/etQQAP4FlpsfzCs3X6"
SetEnv BLOG_CONTACT_URL https://preprod-melina.maison-melina.fr/contact
SetEnv BLOG_AUTHORS Thierry,Christine

########## Sécurité (nécessite mod_headers) ##########
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"

  Header always set Content-Security-Policy "default-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com https://cdnjs.cloudflare.com; connect-src 'self' https://www.maison-melina.fr https://maison-melina.fr https://preprod-melina.maison-melina.fr https://maison-melina-server.vercel.app; media-src 'self' blob: https://www.maison-melina.fr https://maison-melina.fr https://preprod-melina.maison-melina.fr; img-src 'self' data: https: blob:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; script-src 'self' 'unsafe-inline' https://www.google.com/recaptcha/ https://www.gstatic.com/recaptcha/ https://www.googletagmanager.com; frame-src 'self' https://www.google.com/recaptcha/; upgrade-insecure-requests; report-uri /api/csp-report"

  <FilesMatch "\.(woff2?|ttf|otf|eot)$">
    Header set Access-Control-Allow-Origin "*"
  </FilesMatch>
</IfModule>

########## Compression ##########
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

########## Cache ##########
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpg "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff  "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType application/json "access plus 1 month"
  ExpiresByType application/xml  "access plus 1 month"
  ExpiresByType video/mp4  "access plus 1 month"
  ExpiresByType video/webm "access plus 1 month"
</IfModule>

########## Protection ##########
Options -Indexes
ErrorDocument 404 /404.html

########## Types MIME ##########
AddType application/pdf .pdf
AddType font/woff2 .woff2
AddType font/woff  .woff
AddType video/mp4  .mp4
AddType video/webm .webm

<IfModule mod_headers.c>
  <FilesMatch "\.pdf$">
    Header set Content-Type "application/pdf"
    Header set Content-Disposition "inline"
    Header set Accept-Ranges "bytes"
  </FilesMatch>

  <FilesMatch "\.(mp4|webm)$">
    Header set Accept-Ranges "bytes"
    Header append Vary "Accept-Encoding"
    Header set Access-Control-Allow-Origin "*"
    Header set Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
    Header set Access-Control-Allow-Headers "Range"
  </FilesMatch>
</IfModule>

<IfModule mod_authz_core.c>
  <FilesMatch "^(\.env|\.git|composer\.(json|lock)|package(-lock)?\.json|yarn\.lock)$">
    Require all denied
  </FilesMatch>
</IfModule>
<IfModule !mod_authz_core.c>
  <FilesMatch "^(\.env|\.git|composer\.(json|lock)|package(-lock)?\.json|yarn\.lock)$">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>

#############################################
# RÉÉCRITURES / REDIRECTIONS
#############################################
<IfModule mod_rewrite.c>
RewriteEngine On

RewriteCond %{HTTP_HOST} ^preprod-melina\.maison-melina\.fr(:[0-9]+)?$ [NC]
RewriteRule ^ - [E=IS_PREPROD:1]

RewriteRule ^MaisonMelina/qui-sommes-nous/?$ - [G,L,NC]
RewriteRule ^maison-a-saint-just-saint-rambert/?$ - [G,L,NC]
RewriteRule ^MaisonMelina/benefices-economiques/?$ - [G,L,NC]
RewriteRule ^MaisonMelina/creer-votre-maison/?$ - [G,L,NC]
RewriteRule ^MaisonMelina/nos-maisons/feurs/?$ - [G,L,NC]
RewriteRule ^MaisonMelina/nos-maisons/chateauroux/?$ - [G,L,NC]
RewriteRule ^MaisonMelina/nos-maisons/?$ - [G,L,NC]
RewriteRule ^MaisonMelina/?$ - [G,L,NC]
RewriteRule ^MaisonMelina/nos-maisons/saint-didier-en-velay/?$ - [G,L,NC]
RewriteRule ^MaisonMelina/nos-maisons/saint-chamond/?$ - [G,L,NC]
RewriteRule ^MaisonMelina/presse/?$ - [G,L,NC]
RewriteRule ^MaisonMelina/404\.html$ - [G,L,NC]
RewriteRule ^maison-a-saint-didier-en-velay/?$ - [G,L,NC]
RewriteRule ^maison-a-feurs/?$ - [G,L,NC]
RewriteRule ^nos-realisations/?$ - [G,L,NC]
RewriteRule ^contactez-maison-melina/?$ - [G,L,NC]
RewriteRule ^mentions-legales-et-politique-de-confidentialite/?$ - [G,L,NC]
RewriteRule ^la-colocation-senior/?$ - [G,L,NC]
RewriteRule ^creer-votre-maison-partagee/?$ - [G,L,NC]
RewriteRule ^maison-partagee-a-belley/?$ - [G,L,NC]

RewriteCond %{ENV:IS_PREPROD} =1
RewriteRule ^nos-maisons/1/?$ https://preprod-melina.maison-melina.fr/nos-maisons/feurs/ [R=301,L]
RewriteCond %{ENV:IS_PREPROD} =1
RewriteRule ^nos-maisons/2/?$ https://preprod-melina.maison-melina.fr/nos-maisons/saint-chamond/ [R=301,L]
RewriteCond %{ENV:IS_PREPROD} =1
RewriteRule ^nos-maisons/3/?$ https://preprod-melina.maison-melina.fr/nos-maisons/saint-didier-en-velay/ [R=301,L]
RewriteCond %{ENV:IS_PREPROD} =1
RewriteRule ^nos-maisons/4/?$ https://preprod-melina.maison-melina.fr/nos-maisons/saint-just-saint-rambert/ [R=301,L]
RewriteCond %{ENV:IS_PREPROD} =1
RewriteRule ^nos-maisons/5/?$ https://preprod-melina.maison-melina.fr/nos-maisons/chateauroux/ [R=301,L]

RewriteCond %{ENV:IS_PREPROD} !=1
RewriteRule ^nos-maisons/1/?$ https://www.maison-melina.fr/nos-maisons/feurs/ [R=301,L]
RewriteCond %{ENV:IS_PREPROD} !=1
RewriteRule ^nos-maisons/2/?$ https://www.maison-melina.fr/nos-maisons/saint-chamond/ [R=301,L]
RewriteCond %{ENV:IS_PREPROD} !=1
RewriteRule ^nos-maisons/3/?$ https://www.maison-melina.fr/nos-maisons/saint-didier-en-velay/ [R=301,L]
RewriteCond %{ENV:IS_PREPROD} !=1
RewriteRule ^nos-maisons/4/?$ https://www.maison-melina.fr/nos-maisons/saint-just-saint-rambert/ [R=301,L]
RewriteCond %{ENV:IS_PREPROD} !=1
RewriteRule ^nos-maisons/5/?$ https://www.maison-melina.fr/nos-maisons/chateauroux/ [R=301,L]

RewriteCond %{ENV:IS_PREPROD} =1
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://preprod-melina.maison-melina.fr%{REQUEST_URI} [R=301,L]

RewriteCond %{ENV:IS_PREPROD} !=1
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} !^www\.maison-melina\.fr(:[0-9]+)?$ [NC]
RewriteRule ^ https://www.maison-melina.fr%{REQUEST_URI} [R=301,L]

</IfModule>
#############################################
# FIN
#############################################
